    "collapsible-content": {
      "type": "collapsible-content",
      "blocks": {
        "block_1": {
          "type": "accordion",
          "settings": {
            "question": "What is the best sport bottle material for workouts?",
            "answer": "<p>We recommend BPA-free, food-grade stainless steel or high-quality plastic sport bottles for optimal hydration during workouts. These materials are durable, easy to clean, and offer excellent insulation properties.</p>",
            "opened": true
          }
        },
        "block_2": {
          "type": "accordion",
          "settings": {
            "question": "Are your  bottles dishwasher-safe?",
            "answer": "<p>Yes, many of our sport bottles are dishwasher-safe. However, we recommend checking the product specifications or care instructions for each bottle, as some may have specific cleaning recommendations.</p>",
            "opened": false
          }
        },
        "block_3": {
          "type": "accordion",
          "settings": {
            "question": "Do your sport bottles come with a warranty?",
            "answer": "<p>Most of our sport bottles come with a warranty. Warranty periods may vary depending on the specific product. Please refer to the product details or contact our customer support for warranty information.</p>",
            "opened": false
          }
        },
        "20d89e0c-5806-43b3-9510-3d6676afbedc": {
          "type": "accordion",
          "settings": {
            "question": "What size bottle is best for different sports and activities?",
            "answer": "<p>The ideal size of a sports bottle can vary depending on your activity. Generally, smaller bottles (16-24 oz) are great for short workouts, while larger bottles (32-40 oz) are better for longer activities or outdoor adventures. Our team can provide personalized recommendations based on your needs.</p>",
            "opened": false
          }
        }
      },
      "block_order": [
        "block_1",
        "block_2",
        "block_3",
        "20d89e0c-5806-43b3-9510-3d6676afbedc"
